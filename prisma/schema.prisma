generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("admins")
}

model Booking {
  id            String   @id @default(cuid())
  // Customer info
  name          String
  email         String
  phone         String
  address       String
  city          String
  // Equipment
  equipmentType String
  equipmentMake String?
  equipmentYear String?
  // Job
  services      String[] // list of selected services
  issues        String   // free text description
  preferredDate String   // date string from form
  // Admin management
  status        String   @default("pending") // pending | accepted | in_progress | completed | declined
  adminNotes    String?
  partsUsed     String?
  laborHours    Float?
  price         Float?
  invoiceSent      Boolean   @default(false)
  // Quote flow
  quoteToken       String?   @unique
  quoteAmount      Float?
  quoteMessage     String?
  quoteSentAt      DateTime?
  quoteViewedAt    DateTime?
  quoteResponse    String?   // 'accepted' | 'declined'
  quoteRespondedAt DateTime?
  customerId       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("bookings")
}

model Customer {
  id        String      @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  notes     String?
  createdAt DateTime    @default(now())
  equipment Equipment[]

  @@map("customers")
}

model Equipment {
  id             String          @id @default(cuid())
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type           String
  make           String?
  model          String?
  serialNumber   String?
  engineHours    Float?
  notes          String?
  createdAt      DateTime        @default(now())
  serviceRecords ServiceRecord[]

  @@map("equipment")
}

model ServiceRecord {
  id          String    @id @default(cuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  date        String
  engineHours Float?
  services    String[]
  checklist   Json?
  partsUsed   String?
  notes       String?
  laborHours  Float?
  price       Float?
  createdAt   DateTime  @default(now())

  @@map("service_records")
}
